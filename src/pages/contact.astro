---
// @ts-nocheck
import Layout from "../layouts/Layout.astro";
import contactImage from "../assets/images/contact.jpeg";
import { Image } from "astro:assets";
---

<Layout
  title="Tamiko Andrews - An Accomplished Southern Maine Hair Stylist - Contact Me">
  <main>
    <div class="contact-wrapper">
      <div class="image-side">
        <Image
          src={contactImage}
          alt="Tamiko Andrews"
          densities={[1.5, 2]}
          quality="mid"
          width="600"
          class="contact-image"
        />
        <div class="image-overlay"></div>
      </div>
      <div class="form-side">
        <form
          name="netlify-form-example"
          method="POST"
          netlify-honeypot="bot-field"
          data-netlify="true"
          netlify>
          <div class="form-header">
            <span class="script-title">Let's Connect</span>
            <div class="flourish">
              <span class="line"></span>
              <span class="diamond"></span>
              <span class="line"></span>
            </div>
          </div>

          <p class="form-intro">
            I'd love to work at your event! Please fill out the form below and we
            can discuss the details further. Hope to hear from you soon.
          </p>
        <input type="hidden" name="form-name" value="netlify-form-example" />
        <div class="input-container">
          <label for="name">Name</label>
          <input name="name" id="name" required type="text" />
        </div>
        <div class="input-container">
          <label for="email">Email</label>
          <input name="email" id="email" required type="email" />
        </div>
        <div class="input-container">
          <label for="phone">Phone number</label>
          <input name="phone" id="phone" required type="phone" />
        </div>
        <div class="input-container">
          <label for="event-date">Event Date</label>
          <input name="event-date" id="event-date" required type="date" />
        </div>
        <div class="input-container">
          <label for="event">Event Details</label>
          <textarea name="event" id="event" type="text"> </textarea>
        </div>
        <input type="submit" value="Send Message" />
        </form>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes expandLine {
    from { width: 0; }
    to { width: 40px; }
  }

  @keyframes scaleIn {
    from { transform: scale(0) rotate(45deg); }
    to { transform: scale(1) rotate(45deg); }
  }

  main {
    height: 100dvh;
    display: flex;
    overflow: hidden;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
  }

  .image-side {
    position: relative;
    overflow: hidden;
    animation: fadeIn 1s ease-out;
  }

  .contact-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, var(--accent-light));
    pointer-events: none;
  }

  .form-side {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    padding-top: 80px;
    background: var(--accent-gradient);
    animation: fadeInUp 0.8s ease-out;
    overflow: hidden;
  }

  .form-header {
    text-align: center;
    margin-bottom: 0.25rem;
    animation: fadeInUp 0.8s ease-out 0.1s both;
  }

  .script-title {
    font-family: 'Allura', cursive;
    font-size: 2.75rem;
    color: var(--accent-darker);
    display: block;
    line-height: 1.1;
  }

  .flourish {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 0.25rem;
  }

  .flourish .line {
    display: block;
    height: 1px;
    width: 40px;
    background: linear-gradient(to right, transparent, var(--accent-dark), transparent);
    animation: expandLine 1s ease-out 0.3s both;
  }

  .flourish .diamond {
    width: 6px;
    height: 6px;
    background: var(--accent-dark);
    transform: rotate(45deg);
    animation: scaleIn 0.5s ease-out 0.5s both;
  }

  .form-intro {
    text-align: center;
    color: var(--accent-darker);
    margin-bottom: 0.25rem;
    font-size: 0.9rem;
    line-height: 1.5;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  form {
    display: grid;
    gap: 12px;
    max-width: 420px;
    width: 100%;
  }

  .input-container {
    display: grid;
    gap: 4px;
    width: 100%;
    animation: fadeInUp 0.6s ease-out both;
  }

  .input-container:nth-child(3) { animation-delay: 0.25s; }
  .input-container:nth-child(4) { animation-delay: 0.3s; }
  .input-container:nth-child(5) { animation-delay: 0.35s; }
  .input-container:nth-child(6) { animation-delay: 0.4s; }
  .input-container:nth-child(7) { animation-delay: 0.45s; }

  label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-darker);
  }

  input, textarea {
    border: 2px solid var(--accent-dark);
    background: rgba(255, 255, 255, 0.5);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--accent-darker);
    transition: all 0.3s ease;
  }

  input {
    height: 42px;
    padding-inline: 12px;
    width: 100%;
  }

  textarea {
    height: 70px;
    padding: 12px;
    resize: none;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent-darker);
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 4px 20px rgba(99, 87, 77, 0.1);
  }

  input[type="submit"] {
    display: grid;
    place-content: center;
    height: 44px;
    border: 2px solid var(--accent-darker);
    border-radius: 50px;
    background: transparent;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-darker);
    font-weight: 600;
    transition: all 0.4s ease;
    animation: fadeInUp 0.6s ease-out 0.5s both;
    cursor: pointer;
    margin-top: 4px;
  }

  input[type="submit"]:hover {
    background: var(--accent-darker);
    color: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(99, 87, 77, 0.25);
  }

  @media screen and (max-width: 900px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      grid-template-rows: 150px 1fr;
      height: 100dvh;
    }

    .image-side {
      height: 150px;
    }

    .image-overlay {
      background: linear-gradient(to bottom, transparent 40%, var(--accent-light));
    }

    .form-side {
      padding: 16px 20px;
      overflow: hidden;
    }

    .script-title {
      font-size: 2rem;
    }

    .form-intro {
      font-size: 0.85rem;
    }

    form {
      gap: 10px;
    }

    input {
      height: 38px;
    }

    textarea {
      height: 60px;
    }

    input[type="submit"] {
      height: 40px;
    }
  }
</style>
